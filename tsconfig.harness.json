{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": [
      "ES2020"
    ],
    "types": [
      "node"
    ],
    "allowJs": false,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "moduleDetection": "force",
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "scripts/harness-runner.ts",
    "tests/eval-search/eval-search-run.ts",
    "tests/eval-search/eval-search-collect-search.ts"
  ]
}
